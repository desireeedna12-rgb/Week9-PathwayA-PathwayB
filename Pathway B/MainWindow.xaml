<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:week9_pathwayB_loops"
        mc:Ignorable="d"
        Title="Ever After Cafe" Height="450" Width="800">
    <Grid>
        <Button x:Name="btnLoop" 
                Content="Loop" Margin="25,25,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="100" 
                Height="35"
                Click="btnLoop_Click"/> 
        <TextBox x:Name="txtData"
                 HorizontalAlignment="Left"
                 Margin="240,29,0,0"
                 TextWrapping="Wrap"
                 VerticalAlignment="Top"
                 Height="190"
                 Width="98" />
        <ListBox x:Name="lstData" 
                 HorizontalAlignment="Left"
                 Height="auto"
                 Margin="586,53,0,0"
                 VerticalAlignment="Top"
                 Width="137" />
        <Button x:Name="btnClear" 
                Content="Clear" Margin="25,89,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Width="100" 
            Height="35"
            Click="btnClear_Click"/>    


    </Grid>
</Window>
